# 请复制本文件为 .env，并只在本地填写真实 API Key。
# 不要把 .env 上传到 GitHub。

# 是否启用 LLM。无密钥或演示 fallback 时可改为 false。
USE_LLM=true

# OpenAI-compatible LLM API 配置。
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.7-plus

# 可选 Base URL 示例：
# 中国大陆账号：https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际账号：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 中国香港地域：https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
#
# 模型可用性取决于账号权限和服务地域；如 qwen3.7-plus 不可用，可按账号权限改为其他兼容模型。

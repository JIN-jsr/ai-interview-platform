# Do not put your real API key in GitHub.
# Copy this file as .env and fill in your own values locally.

# Recommended for this project:
# China mainland endpoint:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore endpoint:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Hong Kong endpoint:
#   https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Recommended:
#   qwen3.7-plus    high-quality, long context, balanced for demo
#   qwen3.7-max     strongest, but may cost more / require access
#   qwen-plus       stable fallback if qwen3.7 models are unavailable
MODEL_NAME=qwen3.7-plus

# Set to false if you want to test the local fallback mode.
USE_LLM=true
